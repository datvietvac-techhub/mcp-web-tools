# Secret key used by SearXNG for signing (image-proxy HMAC, internal tokens) —
# NOT an API key, never sent by clients. Must be random; SearXNG won't run with
# the default. `./install.sh` generates one automatically. Generate by hand with:
#   openssl rand -hex 32
SEARXNG_SECRET=

# Optional bearer token to protect the Crawl4AI API. Leave empty to disable auth.
CRAWL4AI_API_TOKEN=

# MCP server transport: "http" (streamable-http, good for remote/multi-agent) or
# "stdio" (single local client launched as a subprocess).
MCP_TRANSPORT=http

# Host port for the MCP server (container also binds this internally).
MCP_PORT=8000

# Host port for the FastAPI dev playground launched by `make playground`.
PLAYGROUND_PORT=8001

# Cache TTL in seconds for the MCP layer. Set to 0 to disable that cache.
MCP_CACHE_TTL=300
EXTRACT_CACHE_TTL=1800

# Timeouts (seconds) and parallelism for outbound calls.
REQUEST_TIMEOUT=30
EXTRACT_TIMEOUT=60
MAX_CONCURRENCY=5

# Image tags — override to pin versions for a reproducible install elsewhere.
# Defaults track :latest. Recommended for production: pin at least crawl4ai
# (its API has changed between releases).
#VALKEY_IMAGE=valkey/valkey:8-alpine
#SEARXNG_IMAGE=searxng/searxng:latest
#CRAWL4AI_IMAGE=unclecode/crawl4ai:0.7.4
